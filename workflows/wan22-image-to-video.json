      "latent_image": ["11", 0],
      "seed": 42,
      "steps": 30,
      "cfg": 5.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0
    },
    "class_type": "WanSampler"
  },
  "30": {
    "inputs": {
      "samples": ["20", 0],
      "vae": ["13", 0]
    },
    "class_type": "VAEDecode"
  },
  "40": {
    "inputs": {
